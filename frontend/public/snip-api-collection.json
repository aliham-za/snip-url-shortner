{
  "info": {
    "name": "Snip — URL Shortener API",
    "description": "Shorten URLs instantly with the Snip API.\n\nAuthentication: Pass your API key via the `X-Api-Key` header.\n\nGet your API key from the Snip dashboard → API Keys page.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api/v1/external",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "YOUR_API_KEY_HERE",
      "type": "string"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "X-Api-Key",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{api_key}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Shorten URL",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"original_url\": \"https://example.com/very-long-url-here\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/shorten",
          "host": ["{{base_url}}"],
          "path": ["shorten"]
        },
        "description": "Create a shortened URL.\n\nRequired: `original_url`\nOptional: `custom_slug`, `title`, `subdomain`\n\nIf a subdomain is provided and doesn't exist yet, it will be created automatically."
      }
    },
    {
      "name": "Shorten URL (with custom slug)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"original_url\": \"https://example.com/very-long-url-here\",\n  \"custom_slug\": \"my-link\",\n  \"title\": \"My Custom Link\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/shorten",
          "host": ["{{base_url}}"],
          "path": ["shorten"]
        },
        "description": "Create a shortened URL with a custom slug and title."
      }
    },
    {
      "name": "Shorten URL (with subdomain)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"original_url\": \"https://example.com/very-long-url-here\",\n  \"subdomain\": \"blog\",\n  \"title\": \"Blog Post Link\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/shorten",
          "host": ["{{base_url}}"],
          "path": ["shorten"]
        },
        "description": "Create a shortened URL under a custom subdomain. If the subdomain doesn't exist, it will be created automatically."
      }
    }
  ]
}
